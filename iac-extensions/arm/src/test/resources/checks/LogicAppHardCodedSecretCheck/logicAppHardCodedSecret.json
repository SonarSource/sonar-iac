{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "resources": [
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "noncompliant-hardcoded-auth-header",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Call_API": {
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "https://api.example.com/data",
                "headers": {
                  "Authorization": "Bearer abc123-secret-token"
                }
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "noncompliant-hardcoded-password",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Call_API": {
              "type": "Http",
              "inputs": {
                "method": "GET",
                "uri": "https://api.example.com",
                "authentication": {
                  "type": "Basic",
                  "username": "admin",
                  "password": "P@ssw0rd123!"
                }
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "noncompliant-hardcoded-api-key",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Call_API": {
              "type": "Http",
              "inputs": {
                "method": "GET",
                "uri": "https://api.example.com",
                "headers": {
                  "x-api-key": "sk-live-abc123def456"
                }
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "noncompliant-hardcoded-raw-token",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Call_API": {
              "type": "Http",
              "inputs": {
                "method": "GET",
                "uri": "https://api.example.com",
                "authentication": {
                  "type": "Raw",
                  "value": "Bearer eyJhbGciOi..."
                }
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "compliant-parameterized-secret",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Call_API": {
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "https://api.example.com/data",
                "headers": {
                  "Authorization": "@{concat('Bearer ', parameters('ApiToken'))}"
                }
              }
            }
          },
          "triggers": {},
          "parameters": {
            "ApiToken": {
              "type": "securestring"
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "compliant-arm-parameter",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Call_API": {
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "https://api.example.com/data",
                "authentication": {
                  "type": "ActiveDirectoryOAuth",
                  "secret": "[parameters('apiSecret')]"
                }
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "compliant-no-sensitive-properties",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Send_Email": {
              "type": "ApiConnection",
              "inputs": {
                "method": "post",
                "body": "Hello World",
                "path": "/v2/Mail"
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "noncompliant-nested-scope-auth-header",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Outer_Scope": {
              "type": "Scope",
              "actions": {
                "Call_API": {
                  "type": "Http",
                  "inputs": {
                    "method": "POST",
                    "uri": "https://api.example.com",
                    "headers": {
                      "Authorization": "Bearer nested-token"
                    }
                  }
                }
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "noncompliant-connection-hardcoded-password",
      "location": "[resourceGroup().location]",
      "properties": {
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', resourceGroup().location, 'sql')]"
        },
        "parameterValues": {
          "server": "myserver.database.windows.net",
          "database": "mydb",
          "username": "admin",
          "password": "P@ssw0rd123!"
        }
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "compliant-connection-parameterized-password",
      "location": "[resourceGroup().location]",
      "properties": {
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', resourceGroup().location, 'sql')]"
        },
        "parameterValues": {
          "server": "myserver.database.windows.net",
          "database": "mydb",
          "username": "admin",
          "password": "[parameters('sqlPassword')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "noncompliant-switch-case-hardcoded-secret",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Route": {
              "type": "Switch",
              "expression": "@triggerBody()?['type']",
              "cases": {
                "CaseA": {
                  "case": "A",
                  "actions": {
                    "Call_API": {
                      "type": "Http",
                      "inputs": {
                        "method": "POST",
                        "uri": "https://api.example.com/a",
                        "headers": {
                          "Authorization": "Bearer case-token"
                        }
                      }
                    }
                  }
                }
              },
              "default": {
                "actions": {}
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "noncompliant-switch-default-hardcoded-secret",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Route": {
              "type": "Switch",
              "expression": "@triggerBody()?['type']",
              "cases": {},
              "default": {
                "actions": {
                  "Call_API": {
                    "type": "Http",
                    "inputs": {
                      "method": "GET",
                      "uri": "https://api.example.com/default",
                      "headers": {
                        "x-api-key": "sk-default-deadbeef"
                      }
                    }
                  }
                }
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "noncompliant-parallel-branch-hardcoded-password",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Fan_Out": {
              "type": "Parallel",
              "branches": {
                "Branch1": {
                  "actions": {
                    "Call_API": {
                      "type": "Http",
                      "inputs": {
                        "method": "GET",
                        "uri": "https://api.example.com/branch1",
                        "authentication": {
                          "type": "Basic",
                          "username": "admin",
                          "password": "P@rallelPwd!"
                        }
                      }
                    }
                  }
                },
                "Branch2": {
                  "actions": {
                    "Other_Call": {
                      "type": "Http",
                      "inputs": {
                        "method": "GET",
                        "uri": "https://api.example.com/branch2"
                      }
                    }
                  }
                }
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "compliant-variables-expression",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Call_API": {
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "https://api.example.com/data",
                "headers": {
                  "Authorization": "@variables('MISPKey')"
                }
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "compliant-body-expression",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Call_API": {
              "type": "Http",
              "inputs": {
                "method": "GET",
                "uri": "https://api.example.com/data",
                "authentication": {
                  "type": "Raw",
                  "secret": "@body('Get_secret')?['value']"
                }
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "noncompliant-escaped-at-literal",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Call_API": {
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "https://api.example.com/data",
                "headers": {
                  "Authorization": "@@Bearer literal-at-token"
                }
              }
            }
          },
          "triggers": {}
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "compliant-embedded-interpolation",
      "location": "[resourceGroup().location]",
      "properties": {
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "actions": {
            "Call_API": {
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "https://api.example.com/data",
                "headers": {
                  "Authorization": "Bearer @{variables('Token')}"
                }
              }
            }
          },
          "triggers": {}
        }
      }
    }
  ]
}
